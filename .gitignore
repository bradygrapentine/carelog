**/.vitest-attachments/
**/__tests__/**/__screenshots__/

# Playwright runtime artifacts (re-generated each run)
test-results/

# Lighthouse CI runtime artifacts
.lighthouseci/

# Subagent heartbeat logs (per-session, ephemeral)
.claude/agent-status/

# Codex adversarial-review run artifacts (per-session, ephemeral)
.codex-runs/

# Vercel CLI link state (per-developer, contains project IDs)
.vercel/

# Local notes (post-sprint plan archives, scratch)
.claude/notes/

# Sibling-of-.worktrees variant (older worktree placement)
worktrees/

# Generated runbook HTML (source .md is the artifact)
docs/project-info/runbooks/*.html
