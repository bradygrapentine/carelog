{
  "name": "carelog",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "vitest run",
    "format": "pnpm exec prettier --write .",
    "web": "pnpm --filter web dev",
    "mobile": "pnpm --filter mobile start",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase db push",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:db": "supabase test db",
    "test:all": "pnpm test && pnpm test:db && pnpm test:e2e",
    "a11y:contrast": "node scripts/a11y-contrast.mjs",
    "check:e2e-drift": "node scripts/check-e2e-string-drift.mjs",
    "migration-check": "bash scripts/migration-check.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@supabase/supabase-js": "^2.39.0",
    "@vitest/coverage-v8": "^4.1.4",
    "babel-plugin-module-resolver": "^5.0.0",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.17",
    "turbo": "latest",
    "typescript": "^5.3.0",
    "vite": "^8.0.5",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "vitest": "4.1.4",
      "@vitest/utils": "4.1.4",
      "protobufjs": ">=8.0.2",
      "@xmldom/xmldom": ">=0.9.0",
      "@opentelemetry/auto-instrumentations-node": ">=0.75.0",
      "@opentelemetry/sdk-node": ">=0.217.0",
      "@opentelemetry/exporter-prometheus": ">=0.217.0",
      "vite": "8.0.10",
      "dompurify": ">=3.3.4",
      "follow-redirects": ">=1.15.13",
      "hono": ">=4.12.14",
      "postcss": ">=8.5.10",
      "@tootallnate/once": ">=3.0.1",
      "uuid": ">=14.0.0",
      "axios": ">=1.15.1",
      "fast-uri": ">=3.1.2"
    }
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@expo/html-elements": "^0.10.1",
    "@gluestack-ui/core": "^3.0.10",
    "@gluestack-ui/utils": "^3.0.11",
    "@legendapp/motion": "^2.3.0",
    "nativewind": "^4.1.23",
    "react-aria": "^3.33.0",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-svg": "^15.13.0",
    "react-native-worklets": "^0.5.1",
    "react-stately": "^3.39.0",
    "tailwind-variants": "^0.1.20"
  }
}
