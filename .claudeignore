# Build output and caches — large, auto-generated, not useful for code understanding
.next/
.turbo/
.expo/
dist/
node_modules/
.cache/
.eslintcache
apps/web/.eslintcache

# Package manager lockfiles — too large to be useful context
pnpm-lock.yaml
package-lock.json
yarn.lock

# Environment files — credentials and secrets, never load into context
.env
.env.local
.env.*.local
env.local
.env.sentry-build-plugin

# Test artifacts
test-results/
coverage/
playwright-report/

# Local Supabase state
supabase/.branches/
supabase/.temp/

# Static assets — binary files, not useful for code understanding
public/
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.svg
*.woff
*.woff2
*.ttf

# Logs
*.log

# iOS / Android native — auto-generated, large, not useful for code understanding
apps/mobile/ios/Pods/
apps/mobile/android/.gradle/
apps/mobile/android/build/
*.pbxproj

# Git worktrees (parallel agent scratch space)
.worktrees/

# Plugin cache — installed Claude Code plugins, large binary blobs
.claude/plugins/cache/
