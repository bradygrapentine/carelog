EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_API_URL=http://localhost:3000
# Service role key is NEVER in the mobile app

# Sentry — referenced as ${SENTRY_ORG} / ${SENTRY_PROJECT} in app.json plugin config
# SENTRY_AUTH_TOKEN is required at EAS build time for source-map upload (set via `eas secret:create`).
SENTRY_ORG=
SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=  # EAS build-time only — store as EAS secret, not in plain .env
