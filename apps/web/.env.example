# Public — safe for client bundles
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Server only — NEVER prefix with NEXT_PUBLIC_
# SUPABASE_SERVICE_ROLE_KEY must be a Supabase JWT whose payload role claim
# is "service_role" (e.g. eyJhbGciOiJIUzI1NiIs...). It is NOT the production
# `sb_secret_*` key — using the wrong format causes admin writes to fall back
# to anon and every server-side insert/update fails with an RLS error. TD-118
# adds a runtime guard that throws on local dev when the shape is wrong.
SUPABASE_SERVICE_ROLE_KEY=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=digest@care-log.org
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=  # build-time only, set in Vercel
# OCR_API_KEY=        # Phase 3 — prescription scan
ANTHROPIC_API_KEY=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@caresync.app
